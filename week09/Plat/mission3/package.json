{
  "name": "umc-zustand-cart",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clean:vite": "node -e \"require('node:fs').rmSync('node_modules/.vite',{recursive:true,force:true})\"",
    "dev": "npm run clean:vite && npm run build && vite preview --host 127.0.0.1 --configLoader native",
    "build": "tsc --noEmit && vite build --configLoader native",
    "preview": "vite preview --host 127.0.0.1 --configLoader native"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
